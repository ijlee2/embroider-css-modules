{
  "name": "test-app-for-embroider-css-modules",
  "version": "2.1.10",
  "private": true,
  "description": "Test app for embroider-css-modules",
  "keywords": [
    "css",
    "css-modules",
    "emberjs",
    "embroider",
    "glint",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ijlee2/embroider-css-modules.git"
  },
  "license": "MIT",
  "author": "Isaac J. Lee",
  "exports": {
    "./tests/*": "./tests/*",
    "./*": "./app/*"
  },
  "scripts": {
    "build": "vite build",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:css": "stylelint \"app/**/*.css\" --cache",
    "lint:css:fix": "stylelint \"app/**/*.css\" --fix",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:hbs": "ember-template-lint .",
    "lint:hbs:fix": "ember-template-lint . --fix",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "lint:types": "ember-tsc --noEmit",
    "start": "vite",
    "test": "NODE_ENV=development vite build --mode development && ember test --config-file \"./testem.cjs\" --path dist --test-port 0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@babel/plugin-transform-runtime": "^7.29.7",
    "@babel/plugin-transform-typescript": "^7.29.7",
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.2",
    "@embroider/compat": "^4.1.20",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^4.6.1",
    "@embroider/router": "^3.0.6",
    "@embroider/vite": "^1.7.6",
    "@glimmer/component": "^2.1.1",
    "@glimmer/tracking": "^1.1.2",
    "@glint/ember-tsc": "^1.8.0",
    "@glint/template": "^1.7.7",
    "@glint/tsserver-plugin": "^2.5.6",
    "@rollup/plugin-babel": "^7.1.0",
    "@shared-configs/ember-template-lint": "workspace:*",
    "@shared-configs/eslint-config-ember": "workspace:*",
    "@shared-configs/prettier": "workspace:*",
    "@shared-configs/stylelint": "workspace:*",
    "@shared-configs/testem": "workspace:*",
    "@shared-configs/typescript": "workspace:*",
    "@types/qunit": "^2.19.14",
    "babel-plugin-ember-template-compilation": "^4.0.0",
    "broccoli-asset-rev": "^3.0.0",
    "concurrently": "^10.0.3",
    "decorator-transforms": "^2.3.2",
    "ember-cli": "~7.0.1",
    "ember-cli-app-version": "^7.0.0",
    "ember-cli-babel": "^8.3.1",
    "ember-load-initializers": "^3.0.1",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.0.4",
    "ember-resolver": "^13.2.0",
    "ember-source": "~7.0.0",
    "ember-template-lint": "^7.9.3",
    "embroider-css-modules": "workspace:*",
    "eslint": "^9.39.4",
    "lightningcss": "^1.32.0",
    "prettier": "^3.8.3",
    "qunit": "^2.26.0",
    "qunit-dom": "^3.5.1",
    "strip-test-selectors": "^0.1.0",
    "stylelint": "^17.13.0",
    "typescript": "^5.9.3",
    "vite": "^8.0.16"
  },
  "engines": {
    "node": "22.* || >= 24"
  },
  "ember": {
    "edition": "octane"
  },
  "ember-addon": {
    "type": "app",
    "version": 2
  }
}
