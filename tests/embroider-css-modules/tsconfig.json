{
  "extends": "@shared-configs/typescript/ember-app",
  "compilerOptions": {
    "paths": {
      "test-app-for-embroider-css-modules/tests/*": ["./tests/*"],
      "test-app-for-embroider-css-modules/*": ["./app/*"],
      "*": ["./types/*"]
    },
    "plugins": [
      {
        "name": "@glint/tsserver-plugin"
      }
    ],
    "rootDir": ".",
    "types": [
      "ember-source/types",
      "@embroider/core/virtual",
      "@glint/ember-tsc/types",
      "vite/client"
    ]
  },
  "include": ["app/**/*", "tests/**/*", "types/**/*", "vite.config.mts"]
}
