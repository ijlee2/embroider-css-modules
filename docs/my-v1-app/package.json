{
  "name": "my-v1-app",
  "version": "1.1.0",
  "private": true,
  "description": "An Ember app with embroider-css-modules and Webpack",
  "keywords": [
    "css",
    "css-modules",
    "emberjs",
    "embroider",
    "glint",
    "typescript"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/ijlee2/embroider-css-modules.git"
  },
  "license": "MIT",
  "author": "Isaac J. Lee",
  "directories": {
    "doc": "doc",
    "test": "tests"
  },
  "scripts": {
    "build": "ember build --environment=production",
    "format": "prettier . --cache --write",
    "lint": "concurrently \"pnpm:lint:*(!fix)\" --names \"lint:\"",
    "lint:css": "stylelint \"app/**/*.css\" --cache",
    "lint:css:fix": "stylelint \"app/**/*.css\" --fix",
    "lint:fix": "concurrently \"pnpm:lint:*:fix\" --names \"fix:\" && pnpm format",
    "lint:format": "prettier . --cache --check",
    "lint:js": "eslint . --cache",
    "lint:js:fix": "eslint . --fix",
    "prelint:types": "type-css-modules --src app",
    "lint:types": "ember-tsc --noEmit",
    "start": "ember serve",
    "test": "ember test --test-port 0"
  },
  "devDependencies": {
    "@babel/core": "^7.29.7",
    "@ember/optional-features": "^3.0.0",
    "@ember/string": "^4.0.1",
    "@ember/test-helpers": "^5.4.3",
    "@embroider/broccoli-side-watch": "^1.1.0",
    "@embroider/compat": "^3.9.3",
    "@embroider/config-meta-loader": "^1.0.0",
    "@embroider/core": "^3.5.9",
    "@embroider/legacy-inspector-support": "^0.1.3",
    "@embroider/macros": "^1.20.5",
    "@embroider/router": "^2.1.12",
    "@embroider/webpack": "^4.1.2",
    "@glimmer/component": "^2.1.1",
    "@glimmer/tracking": "^1.1.2",
    "@glint/ember-tsc": "^1.8.7",
    "@glint/template": "^1.7.8",
    "@glint/tsserver-plugin": "^2.5.13",
    "@shared-configs/eslint-config-ember": "workspace:*",
    "@shared-configs/prettier": "workspace:*",
    "@shared-configs/stylelint": "workspace:*",
    "@shared-configs/testem": "workspace:*",
    "@shared-configs/typescript": "workspace:*",
    "@types/qunit": "^2.19.14",
    "autoprefixer": "^10.5.2",
    "broccoli-asset-rev": "^3.0.0",
    "concurrently": "^10.0.3",
    "ember-auto-import": "^2.13.1",
    "ember-cli": "~6.12.0",
    "ember-cli-app-version": "^7.0.0",
    "ember-cli-babel": "^8.3.1",
    "ember-cli-clean-css": "^3.0.0",
    "ember-cli-htmlbars": "^7.0.1",
    "ember-cli-inject-live-reload": "^2.1.0",
    "ember-load-initializers": "^3.0.1",
    "ember-page-title": "^9.0.3",
    "ember-qunit": "^9.1.0",
    "ember-resolver": "^13.2.0",
    "ember-source": "~6.12.0",
    "ember-template-imports": "^4.4.0",
    "embroider-css-modules": "workspace:*",
    "eslint": "^9.39.4",
    "loader.js": "^4.7.0",
    "my-v2-addon": "workspace:*",
    "postcss": "^8.5.16",
    "postcss-loader": "^8.2.1",
    "prettier": "^3.9.4",
    "qunit": "^2.26.0",
    "qunit-dom": "^3.5.1",
    "stylelint": "^17.14.0",
    "type-css-modules": "workspace:*",
    "typescript": "^5.9.3",
    "webpack": "^5.107.2"
  },
  "engines": {
    "node": "22.* || >= 24"
  },
  "ember": {
    "edition": "octane"
  }
}
