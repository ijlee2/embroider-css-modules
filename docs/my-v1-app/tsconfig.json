{
  "extends": "@shared-configs/typescript/ember-app",
  "compilerOptions": {
    "paths": {
      "my-v1-app/tests/*": ["./tests/*"],
      "my-v1-app/*": ["./app/*"],
      "*": ["./types/*"]
    },
    "plugins": [
      {
        "name": "@glint/tsserver-plugin"
      }
    ],
    "rootDir": ".",
    "types": ["ember-source/types", "@glint/ember-tsc/types"]
  },
  "include": ["app/**/*", "tests/**/*", "types/**/*"]
}
