{
  "extends": "@shared-configs/typescript/ember-app",
  "compilerOptions": {
    "paths": {
      "docs-app-for-embroider-css-modules/tests/*": ["./tests/*"],
      "docs-app-for-embroider-css-modules/*": ["./app/*"],
      "*": ["./types/*"]
    },
    "plugins": [
      {
        "name": "@glint/tsserver-plugin"
      }
    ],
    "rootDir": ".",
    "types": [
      "@embroider/core/virtual",
      "@glint/ember-tsc/types",
      "ember-source/types",
      "vite/client"
    ]
  },
  "include": ["app/**/*", "tests/**/*", "types/**/*", "vite.config.mts"],
  "glint": {
    "additionalSpecialForms": {
      "globals": {
        "and": "&&",
        "eq": "===",
        "not": "!",
        "neq": "!==",
        "or": "||"
      }
    }
  }
}
