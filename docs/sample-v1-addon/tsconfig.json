{
  "extends": "@shared-configs/typescript/ember",
  "compilerOptions": {
    "baseUrl": ".",
    "paths": {
      "dummy/tests/*": ["tests/*"],
      "dummy/*": ["tests/dummy/app/*", "app/*"],
      "sample-v1-addon": ["addon"],
      "sample-v1-addon/*": ["addon/*"],
      "sample-v1-addon/test-support": ["addon-test-support"],
      "sample-v1-addon/test-support/*": ["addon-test-support/*"],
      "*": ["types/*"]
    },
    "skipLibCheck": true
  },
  "include": [
    "app/**/*",
    "addon/**/*",
    "tests/**/*",
    "types/**/*",
    "test-support/**/*",
    "addon-test-support/**/*"
  ]
}
